FROM python:3.12-slim

WORKDIR /app

# Copy the entire project
COPY . .

# Install dependencies from the agents requirements
RUN cd apps/agents && pip install --no-cache-dir -r requirements.txt

# Set working directory to agents
WORKDIR /app/apps/agents

# Expose port
EXPOSE 8000

# Run the application
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
